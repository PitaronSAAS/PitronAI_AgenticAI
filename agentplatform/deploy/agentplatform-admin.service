[Unit]
Description=PitronAgent Admin Dashboard
After=network.target

[Service]
Type=exec
User=www-data
WorkingDirectory=/var/www/PitronAI_AgenticAI/agentplatform/admin
EnvironmentFile=/var/www/PitronAI_AgenticAI/agentplatform/.env
ExecStart=/var/www/PitronAI_AgenticAI/agentplatform/venv/bin/streamlit run app.py \
    --server.port 8503 \
    --server.address 127.0.0.1 \
    --server.headless true \
    --server.enableCORS false
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal
SyslogIdentifier=agentplatform-admin

[Install]
WantedBy=multi-user.target
